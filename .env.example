# Copy to .env and fill in. All settings use the TRIAGE_ prefix.

# --- auth ---
TRIAGE_API_KEY=dev-key

# --- execution / persistence ---
# persistence: memory | postgres
# execution:   inline (graph runs in-request) | queue (enqueue to the arq worker)
TRIAGE_PERSISTENCE=memory
TRIAGE_EXECUTION=inline
TRIAGE_DATABASE_URL=postgresql://triage:triage@localhost:5432/triage
TRIAGE_REDIS_URL=redis://localhost:6379/0

# --- LLM / transcription (key-less defaults; set a key + switch provider to use the real ones) ---
TRIAGE_LLM_PROVIDER=heuristic        # heuristic | openai
TRIAGE_OPENAI_API_KEY=
TRIAGE_OPENAI_MODEL=gpt-5.4-mini
TRIAGE_TRANSCRIBER=fake              # fake | deepgram
TRIAGE_DEEPGRAM_API_KEY=
TRIAGE_DEEPGRAM_MODEL=nova-3

# --- policy parameters (tunable, never hard-coded) ---
TRIAGE_CLARIFICATION_CAP=2
TRIAGE_CLARIFICATION_CAP_SENSITIVE=1
TRIAGE_DEBOUNCE_SECONDS=2.0
